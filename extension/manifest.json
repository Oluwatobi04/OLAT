{
  "manifest_version": 3,
  "name": "OLat5 — Live Interview Copilot",
  "version": "0.1.0",
  "description": "Real-time AI interview copilot for Google Meet, Zoom, Teams, and Webex.",
  "permissions": ["tabCapture", "offscreen", "storage", "scripting", "activeTab"],
  "host_permissions": [
    "https://meet.google.com/*",
    "https://*.zoom.us/*",
    "https://teams.microsoft.com/*",
    "https://*.webex.com/*",
    "https://api.deepgram.com/*",
    "https://nhxywzpinkuociddvkvz.supabase.co/*",
    "http://localhost:3000/*"
  ],
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "popup.html", "default_title": "OLat5 Copilot" },
  "content_scripts": [
    {
      "matches": [
        "https://meet.google.com/*",
        "https://*.zoom.us/*",
        "https://teams.microsoft.com/*",
        "https://*.webex.com/*"
      ],
      "js": ["config.js", "content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    { "resources": ["overlay.css"], "matches": ["<all_urls>"] }
  ]
}
